{{!< default}}
{{#post}}
<article class="page">
    {{#if @page.show_title_and_feature_image}}
    <header class="page-header">
        <h1>{{title}}</h1>
        {{#if feature_image}}
        <img class="page-image" src="{{feature_image}}" alt="{{title}}">
        {{/if}}
    </header>
    {{/if}}
    <section class="post-content">
        {{content}}
    </section>
</article>
{{/post}}
