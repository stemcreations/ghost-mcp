# Staff Access Token from your Ghost user profile page (format: id:secret)
GHOST_STAFF_ACCESS_TOKEN=

# Base URL of your Ghost site, e.g. https://yoursite.ghost.io
# (the admin domain, which may differ from your public site domain)
GHOST_ADMIN_URL=

# Optional: Admin API version sent via the Accept-Version header (default: v6.0).
# Set it to match your running Ghost major version, e.g. v6.0.
GHOST_API_VERSION=v6.0

# Optional: serper.dev API key (https://serper.dev). Enables the search-research
# tools: search_serp, expand_keywords, build_content_brief, find_content_gaps.
# Without it those tools are simply not registered; everything else works normally.
SERPER_API_KEY=

# Optional: which research profile to judge keywords against -- general (default),
# saas, wellness, or one you created with create_research_profile. Only used until a
# profile is set via the set_research_profile tool, which persists its own choice.
SERP_PROFILE=

# Optional: extra domains to treat as SERP incumbents, comma-separated. Added to the
# active profile's defaults. Prefer the add_incumbents tool, which persists to disk;
# this is for deployments where the config is fixed and the data dir isn't writable.
SERP_INCUMBENTS=

# Optional: where custom research data (active profile, incumbent lists) is stored.
# Defaults to ~/.ghost-mcp. Set it to "." to keep incumbents.json inside the project
# instead -- it's already gitignored there.
GHOST_MCP_DATA_DIR=
