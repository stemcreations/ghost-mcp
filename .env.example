# Staff Access Token from your Ghost user profile page (format: id:secret)
GHOST_STAFF_ACCESS_TOKEN=

# Base URL of your Ghost site, e.g. https://yoursite.ghost.io
# (the admin domain — may differ from your public site domain)
GHOST_ADMIN_URL=

# Optional: Admin API version sent via the Accept-Version header (default: v6.0).
# Set it to match your running Ghost major version, e.g. v6.0.
GHOST_API_VERSION=v6.0
